{
    "tabWidth": 4,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "jsxSingleQuote": false,
    "printWidth": 100,
    "bracketSpacing": true,
    "arrowParens": "always",
    "trailingComma": "es5",
    "endOfLine": "lf",
    "plugins": [
        "prettier-plugin-tailwindcss"
    ]
}